{
  "schemaVersion": 2,
  "project": {
    "name": "DAR",
    "type": "software",
    "description": "Deep Adversarial Reviews — iterative adversarial review skills for Claude Desktop and Claude Code CLI"
  },
  "repo": {
    "provider": "github",
    "github": {
      "owner": "oxygn-cloud-ai",
      "repo": "deep-adversarial-reviews",
      "defaultBranch": "main",
      "issuesEnabled": true
    }
  },
  "jira": {
    "projectKey": "CPT",
    "epicKey": "CPT-3"
  },
  "host": {
    "sshAlias": "choc-aws4"
  },
  "sessions": {
    "roles": ["master","planner","implementer","fixer","versioner","chk1","chk2","performance","playtester","reviewer","triager","health","learner","releaser","researcher"]
  },
  "defaultProvider": "deepseek",
  "providers": {
    "deepseek": {
      "anthropicBaseUrl": "https://api.deepseek.com/anthropic",
      "apiKeyEnv": "DEEPSEEK_API_KEY",
      "defaultModel": "deepseek-v4-pro[1m]",
      "description": "DeepSeek via Anthropic-compatible API (direct)"
    },
    "anthropic": {
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "defaultModel": "claude-opus-4-8",
      "description": "Anthropic native API"
    }
  },
  "loops": {
    "master": {"intervalMinutes": 5, "driver": "session", "prompt": "loops/master.md", "stateFile": ".claude/state/master.md"},
    "implementer": {"intervalMinutes": 5, "driver": "session", "prompt": "loops/implementer.md", "stateFile": ".claude/state/implementer.md"},
    "fixer": {"intervalMinutes": 5, "driver": "session", "prompt": "loops/fixer.md", "stateFile": ".claude/state/fixer.md"},
    "versioner": {"intervalMinutes": 10, "driver": "session", "prompt": "loops/versioner.md", "stateFile": ".claude/state/versioner.md"},
    "chk1": {"intervalMinutes": 15, "driver": "session", "prompt": "loops/chk1.md", "stateFile": ".claude/state/chk1.md"},
    "chk2": {"intervalMinutes": 15, "driver": "session", "prompt": "loops/chk2.md", "stateFile": ".claude/state/chk2.md"},
    "performance": {"intervalMinutes": 15, "driver": "session", "prompt": "loops/performance.md", "stateFile": ".claude/state/performance.md"},
    "playtester": {"intervalMinutes": 15, "driver": "session", "prompt": "loops/playtester.md", "stateFile": ".claude/state/playtester.md"},
    "reviewer": {"intervalMinutes": 5, "driver": "session", "prompt": "loops/reviewer.md", "stateFile": ".claude/state/reviewer.md"},
    "triager": {"intervalMinutes": 5, "driver": "session", "prompt": "loops/triager.md", "stateFile": ".claude/state/triager.md"},
    "health": {"intervalMinutes": 5, "driver": "session", "prompt": "loops/health.md", "stateFile": ".claude/state/health.md"},
    "learner": {"intervalMinutes": 15, "driver": "session", "prompt": "loops/learner.md", "stateFile": ".claude/state/learner.md"},
    "releaser": {"intervalMinutes": 10, "driver": "session", "prompt": "loops/releaser.md", "stateFile": ".claude/state/releaser.md"}
  }
}
